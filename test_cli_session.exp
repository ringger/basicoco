#!/usr/bin/expect -f

# Set timeout for commands
set timeout 10

# Start the CLI client
spawn python cli_client.py --host localhost --port 5000

# Wait for connection
expect "READY"

# Test FILES command
send "FILES\r"
expect "READY"

# Load the lunar lander program
send "LOAD \"simple_lunar\"\r"
expect "READY"

# Show the program listing
send "LIST\r"
expect "READY"

# Run the game
send "RUN\r"

# Wait for the game to start and show initial state
expect "FUEL:"

# Play the game - provide thrust values
expect "THRUST (0-30)"
send "10\r"

expect "THRUST (0-30)"
send "8\r"

expect "THRUST (0-30)"
send "5\r"

expect "THRUST (0-30)"
send "3\r"

expect "THRUST (0-30)"
send "0\r"

# Wait for landing result
expect {
    "LANDED!" { 
        puts "\n=== GAME COMPLETED ==="
    }
    timeout {
        puts "\n=== GAME TIMEOUT ==="
    }
}

# Wait a moment to see final output
sleep 2

# Exit gracefully
send "\x03"
expect eof

puts "\n=== CLI SESSION COMPLETE ==="