10 REM BOUNCING SYMBOL DEMO
20 REM MOVES A STAR FROM LEFT TO RIGHT AND BACK
30 REM ACROSS A 10-SPACE INTERVAL
40 CLS
50 POS = 10: DIR = 1
60 REM MAIN ANIMATION LOOP
70 FOR I = 1 TO 1000
80 REM CLEAR PREVIOUS POSITION BY PRINTING SPACES
90 FOR J = 10 TO 20: PRINT @(32*12+J)," ";: NEXT J
100 REM PRINT STAR AT CURRENT POSITION
110 PRINT @(32*12+POS),"*";
120 REM UPDATE POSITION AND DIRECTION
130 POS = POS + DIR
140 IF POS = 20 THEN DIR = -1
150 IF POS = 10 THEN DIR = 1
160 REM SMALL DELAY TO MAKE ANIMATION VISIBLE
170 FOR K = 1 TO 50: NEXT K
180 NEXT I
190 PRINT
200 PRINT "ANIMATION COMPLETE!"
210 END