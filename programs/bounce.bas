10 REM BOUNCING STAR ANIMATION
20 REM MOVES * LEFT AND RIGHT ACROSS 10 SPACES
30 CLS
40 POS = 1
50 DIR = 1
60 REM MAIN LOOP - 50 ITERATIONS
70 FOR I = 1 TO 50
80 REM BUILD OUTPUT STRING
90 LINE$ = ""
100 FOR J = 1 TO 10
110 IF J = POS THEN LINE$ = LINE$ + "*"
115 IF J <> POS THEN LINE$ = LINE$ + " "
120 NEXT J
130 PRINT LINE$
140 REM UPDATE POSITION AND DIRECTION
150 POS = POS + DIR
160 IF POS = 10 THEN DIR = -1
170 IF POS = 1 THEN DIR = 1
180 REM SMALL DELAY
190 FOR K = 1 TO 200: NEXT K
200 NEXT I
210 PRINT
220 PRINT "ANIMATION FINISHED!"
230 END