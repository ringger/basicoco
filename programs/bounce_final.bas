10 REM BOUNCING STAR - OPTIMIZED FOR CURRENT SYSTEM
20 CLS
30 PRINT "WATCH THE BOUNCING STAR:"
40 PRINT
50 POS = 1
60 DIR = 1
70 REM SHORTER ANIMATION - 20 STEPS
80 FOR I = 1 TO 20
90 REM CLEAR LINE
100 PRINT "          ";
110 PRINT CHR$(13);
120 REM BUILD STAR LINE
130 LINE$ = ""
140 FOR J = 1 TO 10
150 IF J = POS THEN LINE$ = LINE$ + "*"
160 IF J <> POS THEN LINE$ = LINE$ + " "
170 NEXT J
180 REM PRINT STAR POSITION  
190 PRINT LINE$;
200 PRINT CHR$(13);
210 REM MULTIPLE SHORT DELAYS FOR BETTER TIMING
220 FOR K = 1 TO 50
230 FOR L = 1 TO 100: NEXT L
240 NEXT K
250 REM UPDATE POSITION
260 POS = POS + DIR
270 IF POS = 10 THEN DIR = -1
280 IF POS = 1 THEN DIR = 1
290 NEXT I
300 PRINT
310 PRINT
320 PRINT "DONE!"
330 END