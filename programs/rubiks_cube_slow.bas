10 REM === RUBIK'S CUBE (SLOW DRAW) ===
20 REM DRAWS A 3D RUBIK'S CUBE
30 REM ONE TILE AT A TIME SO YOU
40 REM CAN WATCH IT FORM
50 REM
60 PMODE 4
70 SCREEN 1
80 PCLS
90 REM
100 REM CELL SIZE FOR EACH FACE TILE
110 S = 20
120 REM ISOMETRIC SKEW PER CELL
130 RX = 10
140 RY = 6
150 REM DELAY BETWEEN TILES (MS)
155 DL = 0.3
160 REM ANCHOR: TOP-LEFT OF FRONT FACE
170 AX = 68
180 AY = 60
190 REM RIGHT FACE ORIGIN
200 BX = AX + 3 * S
210 BY = AY
220 REM TOP FACE ORIGIN
230 TX = AX
240 TY = AY
250 REM
260 REM === FACE COLORS ===
270 REM FRONT=RED(4) RIGHT=BLUE(3) TOP=YELLOW(2)
280 FC = 4
290 RC = 3
300 TC = 2
310 REM OUTLINE/BOUNDARY COLOR (GREEN)
320 OC = 1
330 REM BLACK FOR FINAL OUTLINES
340 BC = 0
350 REM
360 REM === DRAW AND FILL ALL FACES ===
370 REM
380 REM FRONT FACE: DRAW GREEN, FILL RED
390 DC = OC
400 PC = FC
410 GOSUB 2000
420 REM RIGHT FACE: DRAW GREEN, FILL BLUE
430 DC = OC
440 PC = RC
450 GOSUB 3000
460 REM TOP FACE: DRAW GREEN, FILL YELLOW
470 DC = OC
480 PC = TC
490 GOSUB 4000
500 REM
510 REM === REDRAW OUTLINES IN BLACK ===
520 REM
530 DC = BC
540 PC = -1
550 GOSUB 2000
560 GOSUB 3000
570 GOSUB 4000
580 REM
590 PRINT
600 PRINT "RUBIK'S CUBE"
610 END
620 REM
2000 REM === FRONT FACE SUBROUTINE ===
2010 REM DC=DRAW COLOR, PC=PAINT COLOR (-1=SKIP)
2020 FOR ROW = 0 TO 2
2030 FOR COL = 0 TO 2
2040 X1 = AX + COL * S
2050 Y1 = AY + ROW * S
2060 X2 = X1 + S
2070 Y2 = Y1 + S
2080 LINE (X1,Y1)-(X2,Y2),DC,B
2090 IF PC >= 0 THEN PAINT (X1 + S/2, Y1 + S/2), PC, OC
2095 PAUSE DL
2100 NEXT COL
2110 NEXT ROW
2120 RETURN
2130 REM
3000 REM === RIGHT FACE SUBROUTINE ===
3010 FOR ROW = 0 TO 2
3020 FOR COL = 0 TO 2
3030 X1 = BX + COL * RX
3040 Y1 = BY + ROW * S - COL * RY
3050 X2 = X1
3060 Y2 = Y1 + S
3070 X3 = X1 + RX
3080 Y3 = Y1 - RY
3090 X4 = X3
3100 Y4 = Y3 + S
3110 LINE (X1,Y1)-(X3,Y3),DC
3120 LINE (X3,Y3)-(X4,Y4),DC
3130 LINE (X4,Y4)-(X2,Y2),DC
3140 LINE (X2,Y2)-(X1,Y1),DC
3150 IF PC >= 0 THEN PAINT (X1 + RX/2, Y1 + S/2 - RY/2), PC, OC
3155 PAUSE DL
3160 NEXT COL
3170 NEXT ROW
3180 RETURN
3190 REM
4000 REM === TOP FACE SUBROUTINE ===
4010 FOR ROW = 0 TO 2
4020 FOR COL = 0 TO 2
4030 X1 = TX + COL * S + ROW * RX
4040 Y1 = TY - ROW * RY
4050 X2 = X1 + RX
4060 Y2 = Y1 - RY
4070 X3 = X2 + S
4080 Y3 = Y2
4090 X4 = X1 + S
4100 Y4 = Y1
4110 LINE (X1,Y1)-(X2,Y2),DC
4120 LINE (X2,Y2)-(X3,Y3),DC
4130 LINE (X3,Y3)-(X4,Y4),DC
4140 LINE (X4,Y4)-(X1,Y1),DC
4150 IF PC >= 0 THEN PAINT (X1 + S/2 + RX/2, Y1 - RY/2), PC, OC
4155 PAUSE DL
4160 NEXT COL
4170 NEXT ROW
4180 RETURN
