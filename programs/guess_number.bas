10 REM ** GUESS THE NUMBER **
20 REM CLASSIC NUMBER GUESSING GAME
30 REM FOR BASICO
40 REM
50 PRINT "GUESS THE NUMBER"
60 PRINT "================"
70 PRINT
80 PRINT "I'M THINKING OF A NUMBER"
90 PRINT "BETWEEN 1 AND 100."
100 PRINT
110 REM PICK A RANDOM NUMBER 1-100
120 N = RND(100)
130 T = 0
140 DONE = 0
150 REM MAIN GAME LOOP
160 WHILE DONE = 0
170   T = T + 1
180   INPUT "YOUR GUESS"; G
190   IF G < 1 OR G > 100 THEN PRINT "ENTER A NUMBER 1 TO 100!": GOTO 180
200   IF G < N THEN PRINT "TOO LOW!"
210   IF G > N THEN PRINT "TOO HIGH!"
220   IF G = N THEN DONE = 1
230 WEND
240 REM CORRECT!
250 PRINT
260 PRINT "*** YOU GOT IT! ***"
270 PRINT "THE NUMBER WAS"; N
280 PRINT "IT TOOK YOU"; T; "TRIES."
290 PRINT
300 IF T <= 3 THEN
310   PRINT "AMAZING! YOU'RE A MIND READER!"
320 ELSE
330   IF T <= 6 THEN
340     PRINT "VERY GOOD!"
350   ELSE
360     IF T <= 10 THEN
370       PRINT "NOT BAD."
380     ELSE
390       PRINT "KEEP PRACTICING!"
400     ENDIF
410   ENDIF
420 ENDIF
430 PRINT
440 INPUT "PLAY AGAIN (Y/N)"; P$
450 IF LEFT$(P$,1) = "Y" THEN GOTO 70
460 PRINT "THANKS FOR PLAYING!"
470 END
