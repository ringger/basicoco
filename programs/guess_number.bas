10 REM ** GUESS THE NUMBER **
20 REM CLASSIC NUMBER GUESSING GAME
30 REM FOR BASICO
40 REM
50 PRINT "GUESS THE NUMBER"
60 PRINT "================"
70 PRINT
80 PRINT "I'M THINKING OF A NUMBER"
90 PRINT "BETWEEN 1 AND 100."
100 PRINT
110 REM PICK A RANDOM NUMBER 1-100
120 N = RND(100)
130 T = 0
140 REM
150 REM MAIN GAME LOOP
160 T = T + 1
170 INPUT "YOUR GUESS"; G
180 IF G < 1 OR G > 100 THEN PRINT "ENTER A NUMBER 1 TO 100!": GOTO 170
190 IF G < N THEN PRINT "TOO LOW!": GOTO 160
200 IF G > N THEN PRINT "TOO HIGH!": GOTO 160
210 REM CORRECT!
220 PRINT
230 PRINT "*** YOU GOT IT! ***"
240 PRINT "THE NUMBER WAS"; N
250 PRINT "IT TOOK YOU"; T; "TRIES."
260 PRINT
270 IF T <= 3 THEN PRINT "AMAZING! YOU'RE A MIND READER!"
280 IF T >= 4 AND T <= 6 THEN PRINT "VERY GOOD!"
290 IF T >= 7 AND T <= 10 THEN PRINT "NOT BAD."
300 IF T > 10 THEN PRINT "KEEP PRACTICING!"
310 PRINT
320 INPUT "PLAY AGAIN (Y/N)"; P$
330 IF LEFT$(P$,1) = "Y" THEN GOTO 70
340 PRINT "THANKS FOR PLAYING!"
350 END
