10 REM === RUBIK'S CUBE ===
20 REM DRAWS A 3D RUBIK'S CUBE
30 REM USING ISOMETRIC PROJECTION
40 MERGE "lib_rubiks_faces"
50 PMODE 4
60 SCREEN 1
70 PCLS
80 REM CELL SIZE AND ISOMETRIC SKEW
90 S = 20
100 RX = 10
110 RY = 6
120 DL = 0
130 REM ANCHOR POINTS
140 AX = 68
150 AY = 60
160 BX = AX + 3 * S
170 BY = AY
180 TX = AX
190 TY = AY
200 REM COLORS: FRONT=RED RIGHT=BLUE TOP=YELLOW
210 FC = 4
220 RC = 3
230 TC = 2
240 OC = 1
250 BC = 0
260 REM DRAW AND FILL ALL FACES
270 DC = OC: PC = FC: GOSUB DrawFront
280 DC = OC: PC = RC: GOSUB DrawRight
290 DC = OC: PC = TC: GOSUB DrawTop
300 REM REDRAW OUTLINES IN BLACK
310 DC = BC: PC = -1
320 GOSUB DrawFront
330 GOSUB DrawRight
340 GOSUB DrawTop
350 PRINT
360 PRINT "RUBIK'S CUBE"
370 END
