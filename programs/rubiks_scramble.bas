10 REM === RUBIK'S CUBE SCRAMBLE ===
20 REM RANDOM FACE AND CUBE ROTATIONS
30 SAFETY OFF
40 PMODE 4: SCREEN 1
50 MERGE "lib_rubiks_engine"
60 GOSUB InitCube
70 GOSUB ShowCube
75 PRINT "RUBIK'S CUBE SCRAMBLE"
80 PRINT
90 REM --- SCRAMBLE WITH 20 RANDOM MOVES ---
92 PRINT "SCRAMBLING (20 MOVES)..."
95 LT=0: LD=0
100 FOR MV=1 TO 20
110   TF=RND(6)
120   IF RND(2)=1 THEN DR=1 ELSE DR=-1
125   IF TF=LT AND DR=-LD THEN GOTO 110
127   LT=TF: LD=DR
130   GOSUB DoTurn
140 NEXT MV
150 PRINT "SCRAMBLED!"
160 END
