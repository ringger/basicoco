10 REM SIMPLE INLINE BOUNCING STAR
20 CLS
30 POS = 1
40 DIR = 1
50 FOR I = 1 TO 30
60 REM BUILD LINE
70 LINE$ = ""
80 FOR J = 1 TO 10
90 IF J = POS THEN LINE$ = LINE$ + "*"
100 IF J <> POS THEN LINE$ = LINE$ + " "
110 NEXT J
120 REM PRINT LINE WITH SEMICOLON (NO NEWLINE)
130 PRINT LINE$;
140 REM CARRIAGE RETURN TO START OF LINE
150 PRINT CHR$(13);
160 REM UPDATE POSITION
170 POS = POS + DIR
180 IF POS = 10 THEN DIR = -1
190 IF POS = 1 THEN DIR = 1
200 REM DELAY
210 FOR K = 1 TO 400: NEXT K
220 NEXT I
230 PRINT
240 PRINT "DONE!"
250 END