10 REM GRAPHICAL BAR CHART FROM FILE
20 REM EXERCISES: OPEN, INPUT#, EOF, CLOSE,
30 REM   ON ERROR GOTO, RESUME, PMODE,
40 REM   SCREEN, PCLS, LINE, PAINT, PSET,
50 REM   DIM, FOR/NEXT, GOSUB/RETURN,
60 REM   LEN, LEFT$, INT, STRING$
70 REM
80 REM === CONFIGURATION ===
90 MX = 10
100 DIM LB$(MX), VL(MX)
110 NC = 0
120 MV = 0
130 F$ = "CHARTDATA.DAT"
140 REM
150 REM === MAIN MENU ===
160 CLS
170 PRINT "*** GRAPHICAL BAR CHART ***"
180 PRINT
190 PRINT "1) LOAD DATA FROM FILE"
200 PRINT "2) ENTER DATA BY HAND"
210 PRINT "3) SAVE DATA TO FILE"
220 PRINT "4) DRAW CHART"
230 PRINT "5) CREATE SAMPLE FILE"
240 PRINT "6) QUIT"
250 PRINT
260 IF NC > 0 THEN PRINT NC; " ITEMS LOADED (MAX "; MV; ")"
270 PRINT
280 INPUT "CHOOSE"; C
290 ON C GOSUB 400, 600, 800, 1000, 1600, 1700
300 IF C <> 6 THEN GOTO 160
310 END
400 REM === LOAD DATA FROM FILE ===
410 NC = 0
420 MV = 0
430 ON ERROR GOTO 490
440 OPEN "I", #1, F$
450 INPUT #1, NC
460 IF NC > MX THEN NC = MX
470 FOR I = 1 TO NC
480 INPUT #1, LB$(I), VL(I)
485 IF VL(I) > MV THEN MV = VL(I)
486 NEXT I
487 CLOSE #1
488 ON ERROR GOTO 0
489 PRINT "LOADED "; NC; " ITEMS FROM "; F$
490 IF NC = 0 THEN PRINT "NO DATA IN FILE (USE OPTION 5)"
495 RETURN
600 REM === ENTER DATA BY HAND ===
610 INPUT "HOW MANY ITEMS (1-10)"; NC
620 IF NC < 1 OR NC > MX THEN PRINT "1 TO 10 PLEASE": GOTO 610
630 MV = 0
640 FOR I = 1 TO NC
650 PRINT "ITEM "; I; ":"
660 INPUT "  LABEL"; LB$(I)
670 INPUT "  VALUE"; VL(I)
680 IF VL(I) < 0 THEN PRINT "  NO NEGATIVES": GOTO 670
690 IF VL(I) > MV THEN MV = VL(I)
700 NEXT I
710 RETURN
800 REM === SAVE DATA TO FILE ===
810 IF NC = 0 THEN PRINT "NO DATA TO SAVE": RETURN
820 OPEN "O", #1, F$
830 PRINT #1, NC
840 FOR I = 1 TO NC
850 PRINT #1, LB$(I); ","; VL(I)
860 NEXT I
870 CLOSE #1
880 PRINT "SAVED "; NC; " ITEMS TO "; F$
890 RETURN
1000 REM === DRAW GRAPHICAL BAR CHART ===
1010 IF NC = 0 THEN PRINT "NO DATA TO PLOT": RETURN
1020 IF MV = 0 THEN PRINT "ALL VALUES ARE ZERO": RETURN
1030 REM SET UP GRAPHICS
1040 PMODE 4, 1
1050 SCREEN 1, 1
1060 PCLS
1070 REM CHART AREA: X=20..245, Y=10..160
1080 X0 = 20
1090 XM = 245
1100 Y0 = 10
1110 YM = 160
1120 REM DRAW AXES
1130 LINE (X0, YM)-(XM, YM)
1140 LINE (X0, Y0)-(X0, YM)
1150 REM DRAW HORIZONTAL GRID AND TICK MARKS
1160 FOR G = 0 TO 4
1170 GY = YM - INT((YM - Y0) * G / 4)
1180 LINE (X0 - 3, GY)-(X0, GY)
1190 FOR GX = X0 + 8 TO XM STEP 8
1200 PSET (GX, GY)
1210 NEXT GX
1220 NEXT G
1230 REM CALCULATE BAR GEOMETRY
1240 TW = XM - X0
1250 BW = INT(TW / NC) - 4
1260 IF BW < 4 THEN BW = 4
1270 REM DRAW BARS
1280 FOR I = 1 TO NC
1290 BX = X0 + INT((I - 1) * TW / NC) + 2
1300 BH = INT((VL(I) / MV) * (YM - Y0))
1310 BY = YM - BH
1320 IF BH > 0 THEN LINE (BX, BY)-(BX + BW, YM), PSET, B
1330 IF BH > 2 THEN PAINT (BX + 1, YM - 1), 1
1340 REM LABEL TICK MARK
1350 LX = BX + INT(BW / 2)
1360 LINE (LX, YM)-(LX, YM + 3)
1370 NEXT I
1380 REM PRINT LEGEND TO TEXT SCREEN
1390 PRINT
1400 PRINT
1410 FOR I = 1 TO NC
1420 L$ = LB$(I)
1430 IF LEN(L$) > 8 THEN L$ = LEFT$(L$, 8)
1440 PRINT L$; "="; VL(I); " ";
1450 NEXT I
1460 PRINT
1470 PRINT "SCALE: MAX = "; MV
1480 RETURN
1600 REM === CREATE SAMPLE DATA FILE ===
1610 OPEN "O", #1, F$
1620 PRINT #1, 6
1630 PRINT #1, "APPLES,120"
1640 PRINT #1, "ORANGES,85"
1650 PRINT #1, "BANANAS,200"
1660 PRINT #1, "GRAPES,150"
1670 PRINT #1, "PEARS,65"
1680 PRINT #1, "LEMONS,95"
1690 CLOSE #1
1695 PRINT "SAMPLE FILE CREATED: "; F$
1696 RETURN
1700 REM === QUIT ===
1710 RETURN
