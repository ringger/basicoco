10 REM REAL-TIME BOUNCING STAR ANIMATION
20 CLS
30 PRINT "REAL-TIME BOUNCING STAR:"
40 PRINT
50 POS = 1
60 DIR = 1
70 FOR I = 1 TO 25
80 REM CLEAR LINE
90 PRINT "          ";
100 PRINT CHR$(13);
110 REM BUILD STAR LINE
120 LINE$ = ""
130 FOR J = 1 TO 10
140 IF J = POS THEN LINE$ = LINE$ + "*"
150 IF J <> POS THEN LINE$ = LINE$ + " "
160 NEXT J
170 REM PRINT STAR POSITION
180 PRINT LINE$;
190 PRINT CHR$(13);
200 REM PAUSE TO SEE ANIMATION
210 PAUSE 0.2
220 REM UPDATE POSITION
230 POS = POS + DIR
240 IF POS = 10 THEN DIR = -1
250 IF POS = 1 THEN DIR = 1
260 NEXT I
270 PRINT
280 PRINT
290 PRINT "REAL-TIME ANIMATION COMPLETE!"
300 END