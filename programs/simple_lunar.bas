10 REM SIMPLE LUNAR LANDER
20 PRINT "LUNAR LANDER"
30 PRINT "============"
40 PRINT
50 A = 1000
60 V = 50
70 F = 500
80 PRINT "ALTITUDE:", A
90 PRINT "VELOCITY:", V
100 PRINT "FUEL:", F
110 PRINT
120 INPUT "THRUST (0-30)"; B
130 IF B < 0 THEN B = 0
140 IF B > 30 THEN B = 30
150 F = F - B
160 A = A - V
170 V = V + 5 - B
180 IF A > 0 THEN GOTO 80
190 PRINT "LANDED!"
200 IF V <= 5 THEN PRINT "GOOD LANDING!"
210 IF V > 5 THEN PRINT "CRASH!"
220 END