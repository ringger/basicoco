10 REM SIMPLE LUNAR LANDER
20 PRINT "LUNAR LANDER"
30 PRINT "============"
40 PRINT
50 A = 1000
60 V = 50
70 F = 500
80 WHILE A > 0
90   PRINT "ALTITUDE:", A
100   PRINT "VELOCITY:", V
110   PRINT "FUEL:", F
120   PRINT
130   INPUT "THRUST (0-30)"; B
140   IF B < 0 THEN B = 0
150   IF B > 30 THEN B = 30
160   F = F - B
170   A = A - V
180   V = V + 5 - B
190 WEND
200 PRINT "LANDED!"
210 IF V <= 5 THEN
220   PRINT "GOOD LANDING!"
230 ELSE
240   PRINT "CRASH!"
250 ENDIF
260 END
