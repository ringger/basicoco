10 REM SIMPLE BOUNCING STAR
20 CLS
30 POS = 1: DIR = 1
40 REM ANIMATION LOOP
50 FOR I = 1 TO 100
60 REM CLEAR LINE AND PRINT STAR AT POSITION
70 PRINT STRING$(POS-1," ") + "*" + STRING$(10-POS," ")
80 REM UPDATE POSITION
90 POS = POS + DIR
100 REM CHANGE DIRECTION AT BOUNDARIES
110 IF POS = 10 THEN DIR = -1
120 IF POS = 1 THEN DIR = 1
130 REM DELAY
140 FOR J = 1 TO 100: NEXT J
150 NEXT I
160 PRINT "DONE!"