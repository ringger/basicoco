10 REM === TEST NEW L/D/B MOVES ===
20 SAFETY OFF
30 PMODE 4: SCREEN 1
40 MERGE "rubiks_engine"
50 GOSUB InitCube
60 GOSUB ShowCube
70 REM TEST: EACH MOVE 4X SHOULD RETURN TO SOLVED
80 REM --- TEST LEFT ---
90 PRINT "TESTING LEFT (4X)..."
100 MS$="LLLL": GOSUB DoMoves
110 GOSUB CheckSolved
120 REM --- TEST DOWN ---
130 PRINT "TESTING DOWN (4X)..."
140 MS$="DDDD": GOSUB DoMoves
150 GOSUB CheckSolved
160 REM --- TEST BACK ---
170 PRINT "TESTING BACK (4X)..."
180 MS$="BBBB": GOSUB DoMoves
190 GOSUB CheckSolved
200 REM --- TEST L L' IDENTITY ---
210 PRINT "TESTING L L'..."
220 MS$="Ll": GOSUB DoMoves
230 GOSUB CheckSolved
240 REM --- TEST SEXY MOVE 6X ---
250 PRINT "TESTING R U R' U' (6X)..."
260 FOR I=1 TO 6: MS$="RUru": GOSUB DoMoves: NEXT I
270 GOSUB CheckSolved
280 REM --- TEST ALL MOVES ---
290 PRINT "TESTING ALL CW+CCW..."
300 MS$="RrUuFfLlDdBb": GOSUB DoMoves
310 GOSUB CheckSolved
320 PRINT: PRINT "ALL TESTS PASSED!"
330 END
340 REM
350 CheckSolved:
360 REM VERIFY CUBE MATCHES SOLVED STATE
365 LOCAL IX, IY, IZ, OK
370 OK=1
380 FOR IX=0 TO 2: FOR IY=0 TO 2
390   IF CL(IX,IY,0,0)<>4 THEN OK=0
400   IF CL(IX,IY,2,1)<>5 THEN OK=0
410 NEXT IY: NEXT IX
420 FOR IY=0 TO 2: FOR IZ=0 TO 2
430   IF CL(2,IY,IZ,2)<>3 THEN OK=0
440   IF CL(0,IY,IZ,3)<>6 THEN OK=0
450 NEXT IZ: NEXT IY
460 FOR IX=0 TO 2: FOR IZ=0 TO 2
470   IF CL(IX,0,IZ,4)<>2 THEN OK=0
480   IF CL(IX,2,IZ,5)<>7 THEN OK=0
490 NEXT IZ: NEXT IX
500 IF OK=1 THEN PRINT "  PASS" ELSE PRINT "  FAIL!": STOP
510 RETURN
