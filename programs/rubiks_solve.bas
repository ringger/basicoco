10 REM === RUBIK'S CUBE SOLVER ===
20 REM BEGINNER'S LAYER-BY-LAYER METHOD
30 SAFETY OFF
40 PMODE 4: SCREEN 1
50 MERGE "rubiks_engine"
55 MERGE "rubiks_solver"
60 GOSUB InitCube
65 GOSUB ShowCube
70 REM --- SCRAMBLE (ANIMATED) ---
72 LT=0: LD=0
74 FOR MV=1 TO 20
76   TF=RND(6)
78   IF RND(2)=1 THEN DR=1 ELSE DR=-1
80   IF TF=LT AND DR=-LD THEN GOTO 76
82   LT=TF: LD=DR
84   GOSUB DoTurn
86 NEXT MV
88 PRINT: PRINT "SCRAMBLED!"
90 REM --- SOLVE (FAST) ---
92 PRINT "SOLVING..."
94 AN=0
100 GOSUB SolveBottomCross
110 GOSUB CheckBottomCross
115 GOSUB SolveBottomCorners
120 GOSUB CheckBottomCorners
122 AN=1
124 GOSUB ShowCube
120 PRINT "DONE!"
130 END
