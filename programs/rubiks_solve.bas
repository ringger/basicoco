10 REM === RUBIK'S CUBE SOLVER ===
20 REM BEGINNER'S LAYER-BY-LAYER METHOD
30 SAFETY OFF
40 PMODE 4: SCREEN 1
50 MERGE "lib_rubiks_engine"
55 MERGE "lib_rubiks_solver"
60 GOSUB InitCube
65 GOSUB ShowCube
68 PRINT "RUBIK'S CUBE SOLVER"
69 PRINT
70 REM --- SCRAMBLE (ANIMATED) ---
72 PRINT "SCRAMBLING..."
74 LT=0: LD=0
76 FOR MV=1 TO 20
78   TF=RND(6)
80   IF RND(2)=1 THEN DR=1 ELSE DR=-1
82   IF TF=LT AND DR=-LD THEN GOTO 78
84   LT=TF: LD=DR
86   GOSUB DoTurn
88 NEXT MV
89 PRINT "SCRAMBLED!": PRINT
90 REM --- SOLVE (FAST) ---
92 AN=0
100 GOSUB SolveBottomCross
110 GOSUB CheckBottomCross
112 AN=1: GOSUB ShowCube
114 PRINT "STEP 1 COMPLETE: BOTTOM CROSS": PRINT
116 AN=0
120 GOSUB SolveBottomCorners
130 GOSUB CheckBottomCorners
132 AN=1: GOSUB ShowCube
134 PRINT "STEP 2 COMPLETE: BOTTOM CORNERS": PRINT
140 PRINT "SOLVED THROUGH STEP 2!"
150 END
