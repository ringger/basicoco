10 REM SLOW BOUNCING STAR - VISIBLE ANIMATION
20 CLS
30 PRINT "BOUNCING STAR ANIMATION:"
40 PRINT
50 POS = 1
60 DIR = 1
70 FOR I = 1 TO 20
80 REM CLEAR LINE WITH SPACES
90 PRINT "          ";
100 PRINT CHR$(13);
110 REM BUILD AND PRINT STAR LINE
120 LINE$ = ""
130 FOR J = 1 TO 10
140 IF J = POS THEN LINE$ = LINE$ + "*"
150 IF J <> POS THEN LINE$ = LINE$ + " "
160 NEXT J
170 PRINT LINE$;
180 PRINT CHR$(13);
190 REM MUCH LONGER DELAY TO SEE MOVEMENT
200 FOR K = 1 TO 2000: NEXT K
210 REM UPDATE POSITION
220 POS = POS + DIR
230 IF POS = 10 THEN DIR = -1
240 IF POS = 1 THEN DIR = 1
250 NEXT I
260 PRINT
270 PRINT
280 PRINT "ANIMATION FINISHED!"
290 END