10 REM ADDRESS BOOK WITH FILE I/O
20 REM EXERCISES: OPEN, CLOSE, PRINT#, INPUT#,
30 REM   LINE INPUT, EOF, ON ERROR GOTO, RESUME,
40 REM   DIM, FOR/NEXT, GOSUB/RETURN, ON...GOTO,
45 REM   WHILE/WEND, PRIVATE
50 DIM NM$(20), PH$(20), CT$(20)
60 NC = 0
70 F$ = "CONTACTS.DAT"
80 REM TRY TO LOAD EXISTING CONTACTS
90 GOSUB 1000
100 REM === MAIN MENU ===
110 PRINT
120 PRINT STRING$(32, "=")
130 PRINT "    ADDRESS BOOK ("; NC; " CONTACTS)"
140 PRINT STRING$(32, "=")
150 PRINT "1) LIST ALL CONTACTS"
160 PRINT "2) ADD A CONTACT"
170 PRINT "3) SEARCH BY NAME"
180 PRINT "4) SAVE AND QUIT"
190 PRINT "5) QUIT WITHOUT SAVING"
200 INPUT "CHOOSE"; C
210 ON C GOTO 300, 500, 700, 900, 950
220 PRINT "INVALID CHOICE"
230 GOTO 100
300 REM === LIST CONTACTS ===
310 IF NC = 0 THEN
320   PRINT "NO CONTACTS YET"
330   GOTO 100
340 ENDIF
350 PRINT
360 PRINT "--- ALL CONTACTS ---"
370 FOR I = 1 TO NC
380   PRINT I; ") "; NM$(I)
390   PRINT "   PHONE: "; PH$(I)
400   PRINT "   CITY:  "; CT$(I)
410 NEXT I
420 PRINT "--- END OF LIST ---"
430 GOTO 100
500 REM === ADD CONTACT ===
510 IF NC >= 20 THEN
520   PRINT "ADDRESS BOOK FULL (20 MAX)"
530   GOTO 100
540 ENDIF
550 NC = NC + 1
560 LINE INPUT "NAME:  "; NM$(NC)
570 LINE INPUT "PHONE: "; PH$(NC)
580 LINE INPUT "CITY:  "; CT$(NC)
590 PRINT NM$(NC); " ADDED!"
600 GOTO 100
700 REM === SEARCH ===
710 LINE INPUT "SEARCH FOR: "; S$
720 F = 0
730 FOR I = 1 TO NC
740   IF INSTR(NM$(I), S$) > 0 THEN
750     PRINT NM$(I); " - "; PH$(I); " - "; CT$(I)
760     F = F + 1
770   ENDIF
780 NEXT I
790 IF F = 0 THEN
800   PRINT "NO MATCHES FOUND"
810 ELSE
820   PRINT F; " MATCH(ES) FOUND"
830 ENDIF
840 GOTO 100
900 REM === SAVE AND QUIT ===
910 GOSUB 1100
920 PRINT "GOODBYE!"
930 END
950 REM === QUIT WITHOUT SAVING ===
960 PRINT "GOODBYE!"
970 END
1000 REM === LOAD CONTACTS FROM FILE ===
1010 ON ERROR GOTO 1080
1020 OPEN "I", #1, F$
1030 ON ERROR GOTO 0
1040 WHILE NOT EOF(1)
1050   NC = NC + 1
1060   INPUT #1, NM$(NC), PH$(NC), CT$(NC)
1065 WEND
1070 CLOSE #1
1075 PRINT "LOADED"; NC; "CONTACT(S) FROM FILE"
1078 RETURN
1080 REM FILE NOT FOUND - START FRESH
1090 PRINT "STARTING NEW ADDRESS BOOK"
1095 RESUME 1078
1100 REM === SAVE CONTACTS TO FILE ===
1105 PRIVATE I
1110 IF NC = 0 THEN
1120   PRINT "NOTHING TO SAVE"
1130   RETURN
1140 ENDIF
1150 OPEN "O", #1, F$
1160 FOR I = 1 TO NC
1170   PRINT #1, NM$(I), PH$(I), CT$(I)
1180 NEXT I
1190 CLOSE #1
1200 PRINT "SAVED"; NC; "CONTACT(S) TO "; F$
1210 RETURN
