10 REM ** LUNAR LANDER **
20 REM CLASSIC SPACE SIMULATION GAME
30 REM FOR TRS-80 COLOR COMPUTER
40 REM 
50 CLEAR 1000
60 REM START SCREEN
70 PRINT "LUNAR LANDER"
80 PRINT "============"
90 PRINT
100 PRINT "YOU ARE PILOTING A LUNAR MODULE"
110 PRINT "TO THE SURFACE OF THE MOON."
120 PRINT
130 PRINT "USE YOUR THRUSTERS WISELY!"
140 PRINT "LAND GENTLY TO SURVIVE."
150 PRINT
160 INPUT "PRESS ENTER TO START", Q$
170 PRINT
180 REM INITIALIZE VARIABLES
190 A = 1000: REM ALTITUDE (FEET)
200 V = 50: REM VELOCITY (FT/SEC)
210 F = 500: REM FUEL (UNITS)
220 T = 0: REM TIME
230 G = 5: REM GRAVITY
240 REM
250 REM MAIN GAME LOOP
260 PRINT
270 PRINT "TIME:", T; "SEC"
280 PRINT "ALTITUDE:", A; "FEET"
290 PRINT "VELOCITY:", V; "FT/SEC"
300 PRINT "FUEL:", F; "UNITS"
310 PRINT
320 IF A <= 0 THEN GOTO 500
330 IF F <= 0 THEN GOTO 400
340 PRINT "THRUST (0-30)?";
350 INPUT B
360 IF B < 0 THEN B = 0
370 IF B > 30 THEN B = 30
380 IF B > F THEN B = F
390 GOTO 420
400 PRINT "OUT OF FUEL!"
410 B = 0
420 REM PHYSICS CALCULATION
430 F = F - B
440 A = A - V
450 V = V + G - B
460 T = T + 1
470 PRINT "THRUST USED:", B
480 FOR I = 1 TO 500: NEXT I
490 GOTO 260
500 REM LANDING SEQUENCE
510 PRINT
520 PRINT "*** LANDING REPORT ***"
530 PRINT
540 PRINT "FINAL VELOCITY:", V; "FT/SEC"
550 PRINT "FUEL REMAINING:", F; "UNITS"
560 PRINT
570 IF V > 5 THEN GOTO 610
580 IF V <= 2 THEN GOTO 640
590 PRINT "ROUGH LANDING, BUT YOU SURVIVED!"
600 GOTO 670
610 PRINT "** CRASH! **"
620 PRINT "YOU HIT TOO HARD!"
630 GOTO 670
640 PRINT "PERFECT LANDING!"
650 PRINT "CONGRATULATIONS, PILOT!"
660 PRINT
670 PRINT "MISSION STATS:"
680 PRINT "LANDING TIME:", T; "SECONDS"
690 PRINT "FUEL EFFICIENCY:", INT((500-F)/T*100)/100
700 PRINT
710 INPUT "PLAY AGAIN (Y/N)", P$
720 IF LEFT$(P$,1) = "Y" THEN GOTO 170
730 PRINT "THANKS FOR PLAYING!"
740 END