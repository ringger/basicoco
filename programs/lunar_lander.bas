10 REM ** LUNAR LANDER **
20 REM CLASSIC SPACE SIMULATION GAME
30 REM FOR TRS-80 COLOR COMPUTER
40 REM
50 CLEAR 1000
60 REM START SCREEN
70 PRINT "LUNAR LANDER"
80 PRINT "============"
90 PRINT
100 PRINT "YOU ARE PILOTING A LUNAR MODULE"
110 PRINT "TO THE SURFACE OF THE MOON."
120 PRINT
130 PRINT "USE YOUR THRUSTERS WISELY!"
140 PRINT "LAND GENTLY TO SURVIVE."
150 PRINT
160 INPUT "PRESS ENTER TO START", Q$
170 PRINT
180 REM INITIALIZE VARIABLES
190 A = 1000: REM ALTITUDE (FEET)
200 V = 50: REM VELOCITY (FT/SEC)
210 F = 500: REM FUEL (UNITS)
220 T = 0: REM TIME
230 G = 5: REM GRAVITY
240 REM
250 REM MAIN GAME LOOP
260 WHILE A > 0
270   PRINT
280   PRINT "TIME:", T; "SEC"
290   PRINT "ALTITUDE:", A; "FEET"
300   PRINT "VELOCITY:", V; "FT/SEC"
310   PRINT "FUEL:", F; "UNITS"
320   PRINT
330   IF F <= 0 THEN
340     PRINT "OUT OF FUEL!"
350     B = 0
360   ELSE
370     PRINT "THRUST (0-30)?";
380     INPUT B
390     IF B < 0 THEN B = 0
400     IF B > 30 THEN B = 30
410     IF B > F THEN B = F
420   ENDIF
430   REM PHYSICS CALCULATION
440   F = F - B
450   A = A - V
460   V = V + G - B
470   T = T + 1
480   PRINT "THRUST USED:", B
490   PAUSE 0.5
500 WEND
510 REM LANDING REPORT
520 PRINT
530 PRINT "*** LANDING REPORT ***"
540 PRINT
550 PRINT "FINAL VELOCITY:", V; "FT/SEC"
560 PRINT "FUEL REMAINING:", F; "UNITS"
570 PRINT
580 IF V > 5 THEN
590   PRINT "** CRASH! **"
600   PRINT "YOU HIT TOO HARD!"
610 ELSE
620   IF V <= 2 THEN
630     PRINT "PERFECT LANDING!"
640     PRINT "CONGRATULATIONS, PILOT!"
650     PRINT
660   ELSE
670     PRINT "ROUGH LANDING, BUT YOU SURVIVED!"
680   ENDIF
690 ENDIF
700 PRINT "MISSION STATS:"
710 PRINT "LANDING TIME:", T; "SECONDS"
720 PRINT "FUEL EFFICIENCY:", INT((500-F)/T*100)/100
730 PRINT
740 INPUT "PLAY AGAIN (Y/N)", P$
750 IF LEFT$(P$,1) = "Y" THEN GOTO 170
760 PRINT "THANKS FOR PLAYING!"
770 END
