10 REM QIX-STYLE BOUNCING COLOR BEAM WITH SOUND
20 REM INITIALIZE GRAPHICS MODE
30 PMODE 4,1: PCLS: SCREEN 1,1
40 REM SET UP VARIABLES
50 X=160: Y=96: DX=2: DY=1
60 X2=100: Y2=150: DX2=-1: DY2=-2
70 C=1: C2=2: LC=0: CC=0: SC=0
75 DIM LX(25), LY(25), LX2(25), LY2(25), LCL(25)
76 REM SOUND VARIABLES
77 F1=200: F2=300: RF=0
80 REM MAIN LOOP
90 REM DRAW LINE BETWEEN TWO POINTS
100 REM ERASE OLDEST LINE
101 IF LC>=25 THEN I=LC MOD 25: LINE(LX(I),LY(I))-(LX2(I),LY2(I)),0
102 REM DRAW NEW LINE
103 LINE(X,Y)-(X2,Y2),C
104 REM STORE LINE IN BUFFER
105 I=LC MOD 25: LX(I)=X: LY(I)=Y: LX2(I)=X2: LY2(I)=Y2: LCL(I)=C: LC=LC+1
110 REM UPDATE BOTH POINTS
120 REM UPDATE FIRST POINT
130 X=X+DX: Y=Y+DY
140 IF X<=0 THEN DX=-DX: X=0: SOUND 800,15
145 IF X>=319 THEN DX=-DX: X=319: SOUND 800,15
150 IF Y<=0 THEN DY=-DY: Y=0: SOUND 600,15
155 IF Y>=191 THEN DY=-DY: Y=191: SOUND 600,15
160 REM UPDATE SECOND POINT
170 X2=X2+DX2: Y2=Y2+DY2
180 IF X2<=0 THEN DX2=-DX2: X2=0: SOUND 400,12
185 IF X2>=319 THEN DX2=-DX2: X2=319: SOUND 400,12
190 IF Y2<=0 THEN DY2=-DY2: Y2=0: SOUND 300,12
195 IF Y2>=191 THEN DY2=-DY2: Y2=191: SOUND 300,12
200 REM CHECK FOR KEYPRESS TO EXIT
210 A$=INKEY$: IF A$<>"" THEN 240
220 REM UPDATE SOUND AND COLORS
221 CC=CC+1: SC=SC+1
222 IF CC>=20 THEN C=C+1: CC=0
223 IF C>8 THEN C=1
224 REM DYNAMIC SOUND BASED ON POSITION
225 F1=200+X/2+Y/3: F2=150+X2/3+Y2/2
226 IF SC>=3 THEN SOUND F1+RF,8: SC=0
227 RF=RF+10: IF RF>100 THEN RF=-100
228 PAUSE 0.02
230 GOTO 90
240 REM EXIT MESSAGE
250 PRINT: PRINT "QIX BEAM STOPPED"
260 END