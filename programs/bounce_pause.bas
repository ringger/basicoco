10 REM BOUNCING STAR WITH PAUSE COMMAND
20 CLS
30 PRINT "BOUNCING STAR ANIMATION:"
40 PRINT
50 POS = 1
60 DIR = 1
70 FOR I = 1 TO 40
80   REM CLEAR LINE WITH SPACES
90   PRINT "          ";
100   PRINT CHR$(13);
110   REM BUILD AND PRINT STAR LINE
120   LINE$ = ""
130   FOR J = 1 TO 10
140     IF J = POS THEN LINE$ = LINE$ + "*"
150     IF J <> POS THEN LINE$ = LINE$ + " "
160   NEXT J
170   PRINT LINE$;
180   PRINT CHR$(13);
190   REM PAUSE FOR VISIBILITY
200   PAUSE 0.3
210   REM UPDATE POSITION
220   POS = POS + DIR
230   IF POS = 10 THEN DIR = -1
240   IF POS = 1 THEN DIR = 1
250 NEXT I
260 PRINT
270 PRINT
280 PRINT "ANIMATION COMPLETE!"
290 END
