10 REM SORTING DEMO - BUBBLE SORT WITH SUBROUTINES
20 REM EXERCISES: GOSUB/RETURN, DATA/READ, DIM,
30 REM   DO/LOOP, MULTI-LINE IF/ELSE/ENDIF,
40 REM   STRING$, ON...GOTO
50 PRINT "*** SORTING DEMONSTRATION ***"
60 PRINT
70 DIM A(10)
80 DIM N$(10)
90 REM READ NAMES FROM DATA STATEMENTS
100 FOR I = 1 TO 10
110 READ N$(I)
120 NEXT I
130 REM READ NUMBERS FROM DATA STATEMENTS
140 FOR I = 1 TO 10
150 READ A(I)
160 NEXT I
170 PRINT "CHOOSE WHAT TO SORT:"
180 PRINT "1) NUMBERS"
190 PRINT "2) NAMES"
200 INPUT "YOUR CHOICE"; C
210 ON C GOTO 230, 300
220 GOTO 170
230 REM SORT NUMBERS
240 PRINT
250 PRINT "BEFORE SORTING:"
260 GOSUB 500
270 GOSUB 700
280 PRINT "AFTER SORTING:"
290 GOSUB 500
295 GOTO 400
300 REM SORT NAMES
310 PRINT
320 PRINT "BEFORE SORTING:"
330 GOSUB 600
340 GOSUB 900
350 PRINT "AFTER SORTING:"
360 GOSUB 600
400 PRINT
410 PRINT STRING$(30, "-")
420 PRINT "SORT COMPLETE!"
430 END
500 REM SUBROUTINE: PRINT NUMBERS
510 FOR I = 1 TO 10
520 PRINT A(I);
530 NEXT I
540 PRINT
550 RETURN
600 REM SUBROUTINE: PRINT NAMES
610 FOR I = 1 TO 10
620 PRINT N$(I); " ";
630 NEXT I
640 PRINT
650 RETURN
700 REM SUBROUTINE: BUBBLE SORT NUMBERS
710 FOR P = 1 TO 9
720 DO
730 S = 0
740 FOR I = 1 TO 10 - P
750 IF A(I) > A(I + 1) THEN
760 T = A(I)
770 A(I) = A(I + 1)
780 A(I + 1) = T
790 S = 1
800 ENDIF
810 NEXT I
820 LOOP WHILE S = 1
830 NEXT P
840 RETURN
900 REM SUBROUTINE: BUBBLE SORT NAMES
910 FOR P = 1 TO 9
920 DO
930 S = 0
940 FOR I = 1 TO 10 - P
950 IF N$(I) > N$(I + 1) THEN
960 T$ = N$(I)
970 N$(I) = N$(I + 1)
980 N$(I + 1) = T$
990 S = 1
1000 ENDIF
1010 NEXT I
1020 LOOP WHILE S = 1
1030 NEXT P
1040 RETURN
1100 REM DATA: NAMES
1110 DATA "ZEBRA","APPLE","MANGO","BANANA"
1120 DATA "CHERRY","DATE","FIG","GRAPE"
1130 DATA "KIWI","LEMON"
1140 REM DATA: NUMBERS
1150 DATA 42, 17, 83, 5, 91
1160 DATA 33, 68, 12, 56, 24
