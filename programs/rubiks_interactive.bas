10 REM === RUBIK'S CUBE INTERACTIVE ===
20 SAFETY OFF
30 PMODE 4: SCREEN 1
40 MERGE "lib_rubiks_engine"
50 GOSUB InitCube
60 GOSUB ShowCube
65 PRINT "RUBIK'S CUBE INTERACTIVE"
70 MainMenu:
80 PRINT
90 PRINT "1)RIGHT 2)TOP 3)FRONT"
100 PRINT "4)ROT-X 5)ROT-Y 6)ROT-Z"
110 INPUT "MOVE(0=QUIT,NEG=CCW)";CH
120 IF CH=0 THEN END
130 IF ABS(CH)<1 OR ABS(CH)>6 THEN GOTO MainMenu
140 TF=ABS(CH)
150 IF CH>0 THEN DR=1 ELSE DR=-1
160 GOSUB DoTurn
170 GOTO MainMenu
