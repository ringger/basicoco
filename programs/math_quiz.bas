10 REM MATH QUIZ GAME
20 REM EXERCISES: WHILE/WEND, EXIT FOR,
30 REM   MULTI-LINE IF/ELSE/ENDIF, ABS, SGN,
40 REM   INSTR, SPACE$, LEFT$, RIGHT$,
50 REM   GOSUB/RETURN, RANDOMIZE, RND, INT
60 RANDOMIZE
70 PRINT "*** MATH QUIZ ***"
80 PRINT
90 SCORE = 0
100 TOTAL = 0
110 QUIT = 0
120 WHILE QUIT = 0
130 TOTAL = TOTAL + 1
140 REM PICK OPERATION: 1=ADD 2=SUB 3=MUL
150 OP = RND(3)
160 A = RND(50)
170 B = RND(20)
180 IF OP = 1 THEN
190 PRINT A; " + "; B; " = ";
200 ANSWER = A + B
210 ELSE
220 IF OP = 2 THEN
230 PRINT A; " - "; B; " = ";
240 ANSWER = A - B
250 ELSE
260 A = RND(12)
270 B = RND(12)
280 PRINT A; " * "; B; " = ";
290 ANSWER = A * B
300 ENDIF
310 ENDIF
320 INPUT G
330 D = ABS(G - ANSWER)
340 IF D = 0 THEN
350 PRINT "CORRECT!"
360 SCORE = SCORE + 1
370 ELSE
380 IF SGN(G - ANSWER) = 1 THEN
390 PRINT "TOO HIGH!"
400 ELSE
410 PRINT "TOO LOW!"
420 ENDIF
430 PRINT "THE ANSWER WAS"; ANSWER
440 ENDIF
450 PRINT
460 GOSUB 700
470 PRINT "SCORE: "; SCORE; " / "; TOTAL
480 PRINT
490 INPUT "CONTINUE (Y/N)"; Q$
500 IF LEFT$(Q$, 1) = "N" OR LEFT$(Q$, 1) = "n" THEN
510 QUIT = 1
520 ENDIF
530 WEND
540 PRINT
550 PRINT "FINAL SCORE: "; SCORE; " / "; TOTAL
560 IF TOTAL > 0 THEN
570 PCT = INT((SCORE / TOTAL) * 100)
580 PRINT "PERCENTAGE: "; PCT; "%"
590 IF PCT >= 80 THEN
600 PRINT "EXCELLENT WORK!"
610 ELSE
620 IF PCT >= 50 THEN
630 PRINT "GOOD EFFORT!"
640 ELSE
650 PRINT "KEEP PRACTICING!"
660 ENDIF
670 ENDIF
680 ENDIF
690 END
700 REM SUBROUTINE: DRAW SCORE BAR
710 PRINT SPACE$(2);
720 IF SCORE > 0 THEN
730 FOR I = 1 TO SCORE
740 PRINT "#";
750 NEXT I
760 ENDIF
770 PRINT
780 RETURN
