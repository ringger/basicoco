10 REM INLINE BOUNCING STAR ANIMATION
20 REM STAR BOUNCES ON THE SAME LINE
30 CLS
40 POS = 1
50 DIR = 1
60 REM MAIN LOOP - 30 ITERATIONS (SHORTER FOR DEMO)
70 FOR I = 1 TO 30
80 REM BUILD OUTPUT STRING
90 LINE$ = ""
100 FOR J = 1 TO 10
110 IF J = POS THEN LINE$ = LINE$ + "*"
115 IF J <> POS THEN LINE$ = LINE$ + " "
120 NEXT J
130 REM PRINT WITH CARRIAGE RETURN (NO NEWLINE)
140 PRINT LINE$ + CHR$(13);
150 REM UPDATE POSITION AND DIRECTION
160 POS = POS + DIR
170 IF POS = 10 THEN DIR = -1
180 IF POS = 1 THEN DIR = 1
190 REM DELAY LOOP
200 FOR K = 1 TO 300: NEXT K
210 NEXT I
220 PRINT
230 PRINT "ANIMATION FINISHED!"
240 END