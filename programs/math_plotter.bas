10 REM MATH FUNCTION PLOTTER
20 REM EXERCISES: SIN, COS, ATN, EXP, LOG,
30 REM   SQR, PMODE, SCREEN, PCLS, PSET, LINE,
40 REM   DRAW, PAINT, COLOR,
50 REM   DIM ARRAYS, ON...GOSUB, PRIVATE
55 PI = 4 * ATN(1)
60 PMODE 4
70 SCREEN 1
80 PCLS
90 REM DRAW AXES
100 LINE (0,96)-(255,96)
110 LINE (128,0)-(128,191)
120 REM DRAW TICK MARKS ON X AXIS
130 FOR I = 0 TO 255 STEP 32
140   LINE (I,94)-(I,98)
150 NEXT I
160 REM DRAW TICK MARKS ON Y AXIS
170 FOR I = 0 TO 191 STEP 24
180   LINE (126,I)-(130,I)
190 NEXT I
200 PRINT "*** MATH PLOTTER ***"
210 PRINT
220 PRINT "1) SINE WAVE"
230 PRINT "2) COSINE WAVE"
240 PRINT "3) EXPONENTIAL DECAY"
250 PRINT "4) SQUARE ROOT"
260 PRINT "5) LISSAJOUS FIGURE"
270 PRINT "6) DRAW STAR"
280 INPUT "CHOOSE"; C
290 ON C GOSUB 400, 500, 600, 750, 850, 1000
300 PRINT "PLOT COMPLETE"
310 END
400 REM === SINE WAVE ===
410 PRIVATE X, Y, RAD
430 FOR X = 0 TO 255
440   REM SCALE X TO RADIANS: 0-255 -> 0-4*PI
450   RAD = (X / 255) * 4 * PI
460   Y = 96 - INT(SIN(RAD) * 80)
470   IF Y >= 0 AND Y <= 191 THEN PSET (X, Y)
480 NEXT X
490 RETURN
500 REM === COSINE WAVE ===
510 PRIVATE X, Y, RAD
520 FOR X = 0 TO 255
530   RAD = (X / 255) * 4 * PI
540   Y = 96 - INT(COS(RAD) * 80)
550   IF Y >= 0 AND Y <= 191 THEN PSET (X, Y)
560 NEXT X
570 RETURN
600 REM === EXPONENTIAL DECAY ===
605 PRIVATE X, Y, XS
610 REM PLOT Y = EXP(-X) SCALED
620 FOR X = 0 TO 255
630   REM SCALE X FROM 0 TO 5
640   XS = (X / 255) * 5
650   Y = 96 - INT(EXP(-XS) * 80)
660   IF Y >= 0 AND Y <= 191 THEN PSET (X, Y)
670 NEXT X
680 REM SHOW THE VALUE AT X=1
690 PRINT "EXP(-1) = "; EXP(-1)
700 PRINT "LOG(EXP(1)) = "; LOG(EXP(1))
710 RETURN
750 REM === SQUARE ROOT ===
755 PRIVATE X, Y, XS
760 FOR X = 128 TO 255
770   REM SCALE X FROM 0 TO 16
780   XS = ((X - 128) / 127) * 16
790   Y = 96 - INT(SQR(XS) * 20)
800   IF Y >= 0 AND Y <= 191 THEN PSET (X, Y)
810 NEXT X
820 RETURN
850 REM === LISSAJOUS FIGURE ===
855 PRIVATE T, RAD, X1, Y1, X2, Y2
860 REM STORE POINTS IN ARRAY
880 DIM PX(361), PY(361)
890 FOR T = 0 TO 360
900   RAD = (T / 180) * PI
910   PX(T) = 128 + INT(SIN(RAD * 3) * 100)
920   PY(T) = 96 + INT(COS(RAD * 2) * 80)
930 NEXT T
940 REM DRAW CONNECTED POINTS
950 FOR T = 1 TO 360
960   X1 = PX(T - 1)
970   Y1 = PY(T - 1)
980   X2 = PX(T)
990   Y2 = PY(T)
995   LINE (X1,Y1)-(X2,Y2)
996 NEXT T
997 RETURN
1000 REM === DRAW A STAR USING TURTLE GRAPHICS ===
1010 REM FIRST CLEAR AND SET UP
1020 PCLS
1030 REM USE DRAW COMMAND FOR A FIVE-POINTED STAR
1040 REM POSITION TO CENTER AREA
1050 PSET (128, 40)
1060 REM DRAW STAR PATTERN
1070 DRAW "D40R40U80R40D40L40U80L40D40"
1080 REM FILL INSIDE WITH PAINT
1090 PAINT (128, 80), 1
1100 RETURN
