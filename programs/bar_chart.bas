10 REM ** ASCII BAR CHART **
20 REM DATA VISUALIZATION DEMO
30 REM FOR BASICO
40 REM
50 PRINT "ASCII BAR CHART MAKER"
60 PRINT "====================="
70 PRINT
80 INPUT "CHART TITLE"; T$
90 PRINT
100 INPUT "HOW MANY ITEMS (2-10)"; N
110 IF N < 2 OR N > 10 THEN PRINT "ENTER 2 TO 10!": GOTO 100
120 DIM L$(N), V(N)
130 MX = 0
140 REM
150 REM GET DATA FROM USER
160 FOR I = 1 TO N
170   PRINT "ITEM"; I; ":"
180   INPUT "  LABEL"; L$(I)
190   INPUT "  VALUE"; V(I)
200   IF V(I) < 0 THEN PRINT "  NO NEGATIVES!": GOTO 190
210   IF V(I) > MX THEN MX = V(I)
220 NEXT I
230 REM
240 REM DRAW THE CHART
250 PRINT
260 PRINT T$
270 FOR I = 1 TO LEN(T$)
280   PRINT "-";
290 NEXT I
300 PRINT
310 PRINT
320 REM SCALE TO 40 COLUMNS MAX
330 IF MX = 0 THEN PRINT "ALL VALUES ARE ZERO!": GOTO 460
340 SC = 40 / MX
350 FOR I = 1 TO N
360   REM PAD LABEL TO 8 CHARS
370   LB$ = L$(I)
380   IF LEN(LB$) > 8 THEN LB$ = LEFT$(LB$, 8)
390   WHILE LEN(LB$) < 8
400     LB$ = LB$ + " "
410   WEND
420   PRINT LB$; " |";
430   BW = INT(V(I) * SC)
440   FOR J = 1 TO BW
450     PRINT "*";
460   NEXT J
470   PRINT " "; V(I)
480 NEXT I
490 PRINT
500 INPUT "MAKE ANOTHER CHART (Y/N)"; A$
510 IF LEFT$(A$,1) = "Y" THEN GOTO 50
520 PRINT "GOODBYE!"
530 END
