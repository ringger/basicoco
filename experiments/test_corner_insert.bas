REM === TEST CORNER INSERTION ALGORITHMS ===
REM EMPIRICALLY DETERMINE CORRECT ALGORITHMS FOR STEP 2
SAFETY OFF
PMODE 4: SCREEN 1
MERGE "lib_rubiks_engine"
AN=0
REM
REM TARGET: BFR CORNER = MAGENTA(7)/RED(4)/BLUE(3)
REM TC1=7 (BOTTOM COLOR), TC2=4 (FRONT), TC3=3 (RIGHT)
TC1=7: TC2=4: TC3=3
REM
REM === FIRST: FIND EXTRACTION SEQUENCES ===
REM TRY VARIOUS EXTRACTIONS FROM BFR AND SEE WHERE CORNER LANDS
REM
PRINT "=== EXTRACTION TESTS ==="
REM
GOSUB InitCube
MS$="ruR": GOSUB DoMoves
GOSUB FindCorner
PRINT "R' U' R: CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="FUf": GOSUB DoMoves
GOSUB FindCorner
PRINT "F U F': CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="Rur": GOSUB DoMoves
GOSUB FindCorner
PRINT "R' U R': CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="fuf": GOSUB DoMoves
GOSUB FindCorner
PRINT "F' U F': CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="rUr": GOSUB DoMoves
GOSUB FindCorner
PRINT "R' U R': CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="fuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "F' U' F: CP=";CP;" CO=";CO
REM
GOSUB InitCube
MS$="FuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "F U' F: CP=";CP;" CO=";CO
REM
PRINT
PRINT "=== INSERTION TESTS ==="
PRINT "PLACE CORNER AT TFR WITH EACH CO, TRY INSERTS"
REM
REM --- SETUP CO=1: EXTRACT WITH fuF THEN ALIGN ---
GOSUB InitCube
MS$="fuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "AFTER fuF: CP=";CP;" CO=";CO
REM NOW ALIGN TO TFR (CP=4) IF NEEDED
IF CP=4 THEN PRINT "ALREADY AT TFR"
IF CP=5 THEN MS$="u": GOSUB DoMoves: PRINT "ALIGNED WITH U'"
IF CP=6 THEN MS$="UU": GOSUB DoMoves: PRINT "ALIGNED WITH UU"
IF CP=7 THEN MS$="U": GOSUB DoMoves: PRINT "ALIGNED WITH U"
GOSUB FindCorner
PRINT "AT TFR: CP=";CP;" CO=";CO
REM TRY INSERTING WITH R U' R'
MS$="rUR": GOSUB DoMoves
GOSUB FindCorner
PRINT "AFTER ruR: CP=";CP;" CO=";CO
REM CHECK IF BFR SOLVED
IF CP=0 AND CO=0 THEN PRINT "  SUCCESS!" ELSE PRINT "  NOT SOLVED"
REM
REM --- RESET AND TRY CO=2 ---
PRINT
GOSUB InitCube
MS$="FUf": GOSUB DoMoves
GOSUB FindCorner
PRINT "AFTER FUf: CP=";CP;" CO=";CO
IF CP=4 THEN PRINT "ALREADY AT TFR"
IF CP=5 THEN MS$="u": GOSUB DoMoves: PRINT "ALIGNED WITH U'"
IF CP=6 THEN MS$="UU": GOSUB DoMoves: PRINT "ALIGNED WITH UU"
IF CP=7 THEN MS$="U": GOSUB DoMoves: PRINT "ALIGNED WITH U"
GOSUB FindCorner
PRINT "AT TFR: CP=";CP;" CO=";CO
REM TRY fuF
MS$="fuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "AFTER fuF: CP=";CP;" CO=";CO
IF CP=0 AND CO=0 THEN PRINT "  SUCCESS!" ELSE PRINT "  NOT SOLVED"
REM
REM --- SETUP CO=0: BOTTOM COLOR ON TOP ---
PRINT
PRINT "=== CO=0 TESTS (BOTTOM ON TOP) ==="
REM NEED TO GET CORNER TO TFR WITH CO=0
REM EXTRACT WITH ruR (gives some CO), then try to find CO=0
GOSUB InitCube
MS$="ruR": GOSUB DoMoves
GOSUB FindCorner
PRINT "AFTER ruR: CP=";CP;" CO=";CO
IF CP=4 THEN PRINT "ALREADY AT TFR"
IF CP=5 THEN MS$="u": GOSUB DoMoves: PRINT "ALIGNED WITH U'"
IF CP=6 THEN MS$="UU": GOSUB DoMoves: PRINT "ALIGNED WITH UU"
IF CP=7 THEN MS$="U": GOSUB DoMoves: PRINT "ALIGNED WITH U"
GOSUB FindCorner
PRINT "AT TFR: CP=";CP;" CO=";CO
REM IF CO=0, TRY R U U R' U' R U R'
IF CO=0 THEN MS$="RUUruRUr": GOSUB DoMoves: GOSUB FindCorner: PRINT "AFTER RUUruRUr: CP=";CP;" CO=";CO: IF CP=0 AND CO=0 THEN PRINT "  SUCCESS!"
IF CO=1 THEN PRINT "GOT CO=1 INSTEAD, SKIPPING"
IF CO=2 THEN PRINT "GOT CO=2 INSTEAD, SKIPPING"
REM
PRINT
PRINT "=== SYSTEMATIC: ALL 3 ORIENTATIONS ==="
REM USE REPEATED EXTRACTION TO CYCLE THROUGH ORIENTATIONS
REM EXTRACTION: ruR FROM SOLVED, THEN REINSERT WRONG, EXTRACT AGAIN
REM
REM APPROACH: USE KNOWN SCRAMBLES TO GET EACH CO
REM CO=0 AT TFR: BOTTOM COLOR ON TOP FACE
REM CO=1 AT TFR: BOTTOM COLOR ON FRONT FACE
REM CO=2 AT TFR: BOTTOM COLOR ON RIGHT FACE
REM
REM LET'S CHECK STICKERS DIRECTLY
REM TFR = (2,0,0): F4=TOP, F0=FRONT, F2=RIGHT
REM
REM --- METHOD: TRY ALL 6 BASIC INSERTIONS FOR EACH CO ---
PRINT
PRINT "=== BRUTE FORCE: TRY EVERY 3-MOVE COMBO ==="
REM FOR EACH EXTRACTION, ALIGN TO TFR, TRY INSERTS
REM
REM EXTRACTION 1: fuF
GOSUB InitCube
MS$="fuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "EXTRACT fuF: CP=";CP;" CO=";CO
REM ALIGN
IF CP=5 THEN MS$="u": GOSUB DoMoves
IF CP=6 THEN MS$="UU": GOSUB DoMoves
IF CP=7 THEN MS$="U": GOSUB DoMoves
GOSUB FindCorner
PRINT "ALIGNED: CP=";CP;" CO=";CO;" (AT TFR)"
REM SHOW STICKERS
PRINT "  F4=";CL(2,0,0,4);" F0=";CL(2,0,0,0);" F2=";CL(2,0,0,2)
REM
REM NOW TRY EACH POSSIBLE 3-MOVE INSERT
REM SAVE CUBE STATE BY RE-EXTRACTING EACH TIME
REM
REM TRY RUr (R U R')
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
IF CP<>4 THEN GOSUB AlignToTFR
MS$="RUr": GOSUB DoMoves
GOSUB FindCorner
PRINT "  RUr: CP=";CP;" CO=";CO
REM
REM TRY Rur (R U' R')
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="Rur": GOSUB DoMoves
GOSUB FindCorner
PRINT "  Rur: CP=";CP;" CO=";CO
REM
REM TRY rUr (hm wrong)
REM TRY ruR (R' U' R)
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="ruR": GOSUB DoMoves
GOSUB FindCorner
PRINT "  ruR: CP=";CP;" CO=";CO
REM
REM TRY rUR (R' U R)
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="rUR": GOSUB DoMoves
GOSUB FindCorner
PRINT "  rUR: CP=";CP;" CO=";CO
REM
REM TRY fuF (F' U' F)
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="fuF": GOSUB DoMoves
GOSUB FindCorner
PRINT "  fuF: CP=";CP;" CO=";CO
REM
REM TRY FuF (F U' F... wrong, need fUF = F' U F)
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="fUF": GOSUB DoMoves
GOSUB FindCorner
PRINT "  fUF: CP=";CP;" CO=";CO
REM
REM TRY FUf (F U F')
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="FUf": GOSUB DoMoves
GOSUB FindCorner
PRINT "  FUf: CP=";CP;" CO=";CO
REM
REM TRY Fuf (F U' F')
GOSUB InitCube: MS$="fuF": GOSUB DoMoves
GOSUB AlignToTFR
MS$="Fuf": GOSUB DoMoves
GOSUB FindCorner
PRINT "  Fuf: CP=";CP;" CO=";CO
REM
PRINT
PRINT "=== EXTRACTION 2: FUf ==="
GOSUB InitCube: MS$="FUf": GOSUB DoMoves
GOSUB FindCorner
PRINT "EXTRACT FUf: CP=";CP;" CO=";CO
GOSUB AlignToTFR
GOSUB FindCorner
PRINT "ALIGNED: CP=";CP;" CO=";CO
PRINT "  F4=";CL(2,0,0,4);" F0=";CL(2,0,0,0);" F2=";CL(2,0,0,2)
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="RUr": GOSUB DoMoves: GOSUB FindCorner
PRINT "  RUr: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="Rur": GOSUB DoMoves: GOSUB FindCorner
PRINT "  Rur: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="ruR": GOSUB DoMoves: GOSUB FindCorner
PRINT "  ruR: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="rUR": GOSUB DoMoves: GOSUB FindCorner
PRINT "  rUR: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="fuF": GOSUB DoMoves: GOSUB FindCorner
PRINT "  fuF: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="fUF": GOSUB DoMoves: GOSUB FindCorner
PRINT "  fUF: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="FUf": GOSUB DoMoves: GOSUB FindCorner
PRINT "  FUf: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="FUf": GOSUB DoMoves: GOSUB AlignToTFR
MS$="Fuf": GOSUB DoMoves: GOSUB FindCorner
PRINT "  Fuf: CP=";CP;" CO=";CO
REM
PRINT
PRINT "=== EXTRACTION 3: ruR ==="
GOSUB InitCube: MS$="ruR": GOSUB DoMoves
GOSUB FindCorner
PRINT "EXTRACT ruR: CP=";CP;" CO=";CO
GOSUB AlignToTFR
GOSUB FindCorner
PRINT "ALIGNED: CP=";CP;" CO=";CO
PRINT "  F4=";CL(2,0,0,4);" F0=";CL(2,0,0,0);" F2=";CL(2,0,0,2)
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="RUr": GOSUB DoMoves: GOSUB FindCorner
PRINT "  RUr: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="Rur": GOSUB DoMoves: GOSUB FindCorner
PRINT "  Rur: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="ruR": GOSUB DoMoves: GOSUB FindCorner
PRINT "  ruR: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="rUR": GOSUB DoMoves: GOSUB FindCorner
PRINT "  rUR: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="fuF": GOSUB DoMoves: GOSUB FindCorner
PRINT "  fuF: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="fUF": GOSUB DoMoves: GOSUB FindCorner
PRINT "  fUF: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="FUf": GOSUB DoMoves: GOSUB FindCorner
PRINT "  FUf: CP=";CP;" CO=";CO
REM
GOSUB InitCube: MS$="ruR": GOSUB DoMoves: GOSUB AlignToTFR
MS$="Fuf": GOSUB DoMoves: GOSUB FindCorner
PRINT "  Fuf: CP=";CP;" CO=";CO
REM
PRINT "DONE"
END
REM
AlignToTFR:
GOSUB FindCorner
IF CP=4 THEN RETURN
IF CP=5 THEN MS$="u": GOSUB DoMoves: RETURN
IF CP=6 THEN MS$="UU": GOSUB DoMoves: RETURN
IF CP=7 THEN MS$="U": GOSUB DoMoves: RETURN
REM BOTTOM CORNER - EXTRACT FIRST
IF CP=0 THEN MS$="ruR": GOSUB DoMoves: GOTO AlignToTFR
IF CP=1 THEN MS$="FUf": GOSUB DoMoves: GOTO AlignToTFR
IF CP=2 THEN MS$="BUb": GOSUB DoMoves: GOTO AlignToTFR
IF CP=3 THEN MS$="LUl": GOSUB DoMoves: GOTO AlignToTFR
RETURN
